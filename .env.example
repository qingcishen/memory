# ---- Supabase ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# ---- LLM (提取 / reflection / 矛盾判断 / 编排器内心独白) ----
# DeepSeek 兼容 OpenAI SDK
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_key
LLM_MODEL=deepseek-chat

# ---- 编排器回复模型 (可选, "好模型"; 不配置则退回 LLM_MODEL) ----
REPLY_MODEL=deepseek-chat

# ---- Embedding ----
# 用 OpenAI 兼容端点; 维度需与 schema.sql 的 vector(1536) 一致 (embeddings.js 会请求 dimensions:1536)。
# OpenAI:     EMBED_BASE_URL=https://api.openai.com/v1                              EMBED_MODEL=text-embedding-3-small
# Gemini:     EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  EMBED_MODEL=gemini-embedding-001
# 换模型记得确认输出维度与 schema.sql 的 vector(维度) 一致。
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=your_embedding_key
EMBED_MODEL=text-embedding-3-small
