# ---- Supabase ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# ---- LLM (提取 / reflection / 矛盾判断 / 编排器内心独白) ----
# DeepSeek 兼容 OpenAI SDK
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_key
LLM_MODEL=deepseek-chat

# ---- 编排器回复模型 (可选, "好模型"; 不配置则退回 LLM_MODEL) ----
REPLY_MODEL=deepseek-chat

# ---- Embedding ----
# 用 OpenAI 兼容端点; 维度需与 schema.sql 的 vector(1536) 一致 (embeddings.js 会请求 dimensions:1536)。
# OpenAI:     EMBED_BASE_URL=https://api.openai.com/v1                              EMBED_MODEL=text-embedding-3-small
# Gemini:     EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  EMBED_MODEL=gemini-embedding-001
# 换模型记得确认输出维度与 schema.sql 的 vector(维度) 一致。
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=your_embedding_key
EMBED_MODEL=text-embedding-3-small

# ---- Telegram bot (optional, local polling) ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Optional: comma-separated chat IDs. Leave empty to allow all chats that can reach the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_COMPANION_NAME=小忆
TELEGRAM_SUBJECT_NAME=你
TELEGRAM_COMPANION_ID=default
# 人设 JSON 路径 (companions/<id>.json); 不配置则默认 companions/${TELEGRAM_COMPANION_ID}.json
TELEGRAM_PERSONA_FILE=
# 历史存储: supabase(默认) | local (本地 JSON 文件)
TELEGRAM_HISTORY_STORE=supabase
# TELEGRAM_HISTORY_STORE=local 时的存储文件路径, 默认 logs/chat-history.json
TELEGRAM_HISTORY_FILE=
# TELEGRAM_HISTORY_STORE=local 时每个会话最多保留多少轮历史, 默认 80
TELEGRAM_HISTORY_MAX_TURNS=
# 单进程锁文件路径, 防止重复启动, 默认 .telegram-bot.lock
TELEGRAM_LOCK_FILE=
# 长时间空闲时打心跳日志的间隔 (ms), 默认 60000
TELEGRAM_IDLE_LOG_MS=
# long polling 超时秒数, 默认 25
TELEGRAM_POLL_TIMEOUT_SECONDS=
# 单次回复生成的超时 (ms), 默认 90000
TELEGRAM_REPLY_TIMEOUT_MS=

# ---- L3 真实世界感知 · 天气 (可选, 不配置则用默认城市/不带经纬度) ----
WEATHER_PLACE=武汉
WEATHER_LAT=
WEATHER_LON=
